# Server Configuration
PORT=3001
NODE_ENV=development

# Database Configuration (PlanetScale)
DATABASE_URL='your_database_url_here'

# JWT Configuration
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Redis Configuration (Optional)
REDIS_URL=redis://localhost:6379

# 阿里云配置
ALIYUN_REGION=your_region_here
ALIYUN_ACCESS_KEY_ID=your_access_key_id_here
ALIYUN_ACCESS_KEY_SECRET=your_access_key_secret_here

# 源数据库配置（本地）
SOURCE_DB_HOST=127.0.0.1
SOURCE_DB_USER=root
SOURCE_DB_PASSWORD=your_password
SOURCE_DB_NAME=dianshang

# 目标数据库配置（SQLPub）
DEST_DB_HOST=mysql.sqlpub.com
DEST_DB_USER=dianshang
DEST_DB_PASSWORD=your_password
DEST_DB_NAME=dianshang

# 日志配置
LOG_LEVEL=info
LOG_FILE=sync.log

# 同步配置
BATCH_SIZE=1000